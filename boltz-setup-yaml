#!/bin/bash
# Non-interactive YAML generation for Boltz predictions.
# Resolve the directory this script lives in (works even via symlink in PATH)
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
PYTHONPATH="$SCRIPT_DIR" exec python3 -c "from boltz_tools.cli_yaml import yaml_main; yaml_main()" "$@"
